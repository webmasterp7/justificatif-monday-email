# Microsoft Graph / Azure app
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_MAILBOX_USER_ID=
MS_INBOX_FOLDER=Inbox
MS_PROCESSED_FOLDER=Processed
