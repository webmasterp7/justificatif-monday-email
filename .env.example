# ── hypermail-mcp ──

# Encryption key for OAuth tokens (required).
# Generate: openssl rand -hex 32
HYPERMAIL_MCP_KEY=

# Azure/Entra ID app registration (required for Outlook).
MS_CLIENT_ID=
MS_TENANT_ID=common

# Watch config (overrides hypermail-config.json).
# HYPERMAIL_WATCH_POLL_INTERVAL=60
# HYPERMAIL_WATCH_SCRIPT_PATH=/scripts/on-email.mjs
# HYPERMAIL_WATCH_SCRIPT_TIMEOUT_MS=30000
# HYPERMAIL_WATCH_SCRIPT_RETRY_MAX_ATTEMPTS=5
# HYPERMAIL_WATCH_SCRIPT_RETRY_BASE_DELAY_MS=1000

# ── Monday.com ──

# API v2 token (required).
MONDAY_API_TOKEN=

# Numeric board ID (required).
MONDAY_BOARD_ID=

# Group ID for new items (defaults to "topics").
# MONDAY_GROUP_ID=topics

# Column IDs (required — discover via monday.com API or UI).
# These must match text/text/text/date column types respectively.
MONDAY_COL_SENDER=
MONDAY_COL_EMAIL=
MONDAY_COL_SUBJECT=
MONDAY_COL_DATE=

# Skip column ID validation on startup (emergency override).
# MONDAY_SKIP_VALIDATION=true
